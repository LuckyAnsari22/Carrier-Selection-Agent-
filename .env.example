# CarrierIQ Backend Configuration
# Copy this to .env and fill in your actual keys

# Anthropic Claude API Key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Exa API Key (optional - for live research)
EXA_API_KEY=

# Langfuse Observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Database
DB_URL=sqlite:///./data/outcomes.db

# Model
MODEL=claude-sonnet-4-20250514

# Debug mode
DEBUG=False
